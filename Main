  </div>

  <div id="tabs">
    <button class="tab-btn active" onclick="showPage('dash', this)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Tableau
    </button>
    <button class="tab-btn" onclick="showPage('add', this)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
      Ajouter
    </button>
    <button class="tab-btn" onclick="showPage('history', this)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
      Historique
    </button>
    <button class="tab-btn" onclick="showPage('rules', this)">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><path d="M12 8v4l2 2"/></svg>
      Règles
    </button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── STATE ──────────────────────────────────────────────
let trades = JSON.parse(localStorage.getItem('tradelog_trades') || '[]');
let currentDir = null;
let currentResult = null;
let currentEmo = null;
let currentFilter = 'all';

// ── NAV ────────────────────────────────────────────────
function showPage(id, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  btn.classList.add('active');
  if (id === 'dash') refreshDash();
  if (id === 'history') renderHistory();
}

// ── FORM ───────────────────────────────────────────────
function selectDir(d) {
  currentDir = d;
  document.querySelectorAll('.dir-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.dir-btn.' + d.toLowerCase()).classList.add('active');
}
function selectResult(r) {
  currentResult = r;
  document.querySelectorAll('.result-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.result-btn.' + r).classList.add('active');
}
function selectEmo(el, e) {
  currentEmo = e;
  document.querySelectorAll('.emo-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
}

function saveTrade() {
  const asset = document.getElementById('f-asset').value.trim().toUpperCase();
  const pnl = parseFloat(document.getElementById('f-pnl').value);
  const entry = parseFloat(document.getElementById('f-entry').value) || null;
  const exit = parseFloat(document.getElementById('f-exit').value) || null;
  const notes = document.getElementById('f-notes').value.trim();
  const setup = document.getElementById('f-setup').checked;

  if (!asset || !currentResult) {
    showToast('⚠️ Remplis au minimum l\'actif et le résultat');
    return;
  }

  const trade = {
    id: Date.now(),
    date: new Date().toISOString(),
    asset, pnl: isNaN(pnl) ? 0 : pnl, entry, exit,
    direction: currentDir, result: currentResult,
    emotion: currentEmo, setup, notes
  };

  trades.unshift(trade);
  localStorage.setItem('tradelog_trades', JSON.stringify(trades));
  showToast('✅ Trade enregistré !');
  resetForm();
  refreshDash();
}

function resetForm() {
  ['f-asset','f-pnl','f-entry','f-exit','f-notes'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('f-setup').checked = false;
  document.querySelectorAll('.dir-btn, .result-btn, .emo-btn').forEach(b => b.classList.remove('active'));
  currentDir = null; currentResult = null; currentEmo = null;
}

// ── DASHBOARD ──────────────────────────────────────────
function refreshDash() {
  const total = trades.length;
  const pnl = trades.reduce((s, t) => s + (t.pnl || 0), 0);
  const wins = trades.filter(t => t.result === 'win').length;
  const losses = trades.filter(t => t.result === 'loss').length;
  const wr = total ? Math.round((wins / total) * 100) : 0;
  const best = total ? Math.max(...trades.map(t => t.pnl || 0)) : 0;
  const worst = total ? Math.min(...trades.map(t => t.pnl || 0)) : 0;
  const bestTrade = trades.find(t => (t.pnl || 0) === best);
  const worstTrade = trades.find(t => (t.pnl || 0) === worst);
  const setupOk = trades.filter(t => t.setup).length;
  const disciplinePct = total ? Math.round((setupOk / total) * 100) : 0;

  // streak
  let streak = 0; let streakType = '';
  for (let t of trades) {
    if (streak === 0) { streakType = t.result; streak = 1; }
    else if (t.result === streakType) streak++;
    else break;
  }

  document.getElementById('stat-pnl').textContent = (pnl >= 0 ? '+' : '') + '$' + pnl.toFixed(2);
  document.getElementById('stat-pnl').className = 'stat-value ' + (pnl >= 0 ? 'green' : 'red');
  document.getElementById('stat-pnl-sub').textContent = total + ' trade' + (total > 1 ? 's' : '');
  document.getElementById('stat-wr').textContent = wr + '%';
  document.getElementById('stat-wr-sub').textContent = wins + 'W / ' + losses + 'L';
  document.getElementById('stat-best').textContent = '+$' + best.toFixed(2);
  document.getElementById('stat-best-sub').textContent = bestTrade ? bestTrade.asset : '—';
  document.getElementById('stat-worst').textContent = '$' + worst.toFixed(2);
  document.getElementById('stat-worst-sub').textContent = worstTrade ? worstTrade.asset : '—';
  document.getElementById('discipline-pct').textContent = disciplinePct + '%';
  document.getElementById('discipline-bar').style.width = disciplinePct + '%';

  const sn = document.getElementById('streak-num');
  const sl = document.getElementById('streak-label');
  const ss = document.getElementById('streak-sub');
  sn.textContent = streak;
  if (streakType === 'win') { sn.style.color = 'var(--accent)'; sl.textContent = 'Série gagnante 🔥'; ss.textContent = 'Continue comme ça !'; }
  else if (streakType === 'loss') { sn.style.color = 'var(--red)'; sl.textContent = 'Série perdante ⚠️'; ss.textContent = streak >= 2 ? 'STOP — Pose-toi !' : 'Reste discipliné.'; }
  else { sn.style.color = 'var(--accent)'; sl.textContent = 'Série en cours'; ss.textContent = 'Commence à trader !'; }

  const d = new Date();
  document.getElementById('header-sub').textContent = d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
}

// ── HISTORY ────────────────────────────────────────────
function setFilter(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderHistory();
}

function renderHistory() {
  let filtered = trades;
  if (currentFilter === 'win') filtered = trades.filter(t => t.result === 'win');
  else if (currentFilter === 'loss') filtered = trades.filter(t => t.result === 'loss');
  else if (currentFilter === 'fomo') filtered = trades.filter(t => t.emotion === 'FOMO');
  else if (currentFilter === 'nosetup') filtered = trades.filter(t => !t.setup);

  const el = document.getElementById('trades-list');
  if (!filtered.length) {
    el.innerHTML = `<div class="empty-state"><div class="e-icon">📭</div><p>Aucun trade ici.<br>Commence à enregistrer tes trades !</p></div>`;
    return;
  }

  el.innerHTML = filtered.map(t => {
    const d = new Date(t.date);
    const dateStr = d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }) + ' à ' + d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    const pnlStr = (t.pnl >= 0 ? '+' : '') + '$' + (t.pnl || 0).toFixed(2);
    const dirTag = t.direction ? `<span class="trade-tag ${t.direction.toLowerCase()}">${t.direction}</span>` : '';
    const setupTag = t.setup !== undefined ? `<span class="trade-tag ${t.setup ? 'setup-ok' : 'setup-no'}">${t.setup ? '✅ Setup' : '⚠️ Hors setup'}</span>` : '';
    const emoTag = t.emotion ? `<span class="trade-tag">${t.emotion}</span>` : '';
    const noteHtml = t.notes ? `<div class="trade-note">${t.notes}</div>` : '';
    return `<div class="trade-item ${t.result}">
      <div class="trade-top">
        <div class="trade-asset">${t.asset || '—'}</div>
        <div class="trade-pnl ${t.result}">${pnlStr}</div>
      </div>
      <div class="trade-meta">${dirTag}${setupTag}${emoTag}</div>
      <div class="trade-date">${dateStr}</div>
      ${noteHtml}
    </div>`;
  }).join('');
}

// ── TOAST ──────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ── INIT ───────────────────────────────────────────────
refreshDash();
</script>
</body>
</html>
